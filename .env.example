# Copy to .env.site and fill values for your server.
# Used by docker-compose.site.yml (api service).

# CORS
ALLOW_ORIGINS=https://tradeforge.art,https://www.tradeforge.art,http://localhost:8088,http://127.0.0.1:8088

# Titan email SMTP (SSL)
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=support@tradeforge.art
SMTP_PASS=CHANGE_ME
SMTP_FROM=support@tradeforge.art
SMTP_TLS=0
SMTP_SSL=1
SMTP_TIMEOUT=15

# Security
EMAIL_CODE_SECRET=CHANGE_ME_LONG_RANDOM
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
OWNER_EMAILS=

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://tradeforge.art/payment-success.html
YOOKASSA_CANCEL_URL=https://tradeforge.art/payment-cancel.html
YOOKASSA_PAYMENT_METHOD=

# Prodamus
PRODAMUS_SECRET_KEY=
PRODAMUS_PAYMENT_URL=
PRODAMUS_RETURN_URL=https://tradeforge.art/payment-success.html
PRODAMUS_CANCEL_URL=https://tradeforge.art/payment-cancel.html
PRODAMUS_WEBHOOK_URL=https://api.tradeforge.art/billing/prodamus/webhook
PRODAMUS_PAYMENT_METHOD=
PRODAMUS_DEMO_MODE=0
